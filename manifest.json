{
    "manifest_version": 3,
    "name": "New Version ClickSense",
    "version": "2.0.0",
    "minimum_chrome_version": "120",
    "description": "AI-powered step-by-step guidance for browser tasks. Python-backed.",
    "permissions": [
        "scripting", "tabs", "storage", "sidePanel", "debugger"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "icons": {
        "16": "images/seeact_icon_16.png",
        "32": "images/seeact_icon_32.png",
        "48": "images/seeact_icon_48.png",
        "128": "images/seeact_icon_128.png"
    },
    "background": {
        "service_worker": "extension/background.js"
    },
    "side_panel": {
        "default_path": "extension/side_panel.html"
    },
    "action": {
        "default_title": "Open ClickSense"
    }
}
